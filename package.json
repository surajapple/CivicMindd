{
  "name": "civicmind",
  "version": "2.0.0",
  "description": "CivicMind — Non-partisan, accessible election education assistant powered by Google Gemini AI",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "node server/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/ server/ tests/ --ext .js",
    "lint:fix": "eslint src/ server/ tests/ --ext .js --fix"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/utils/**/*.js",
      "server/**/*.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "src/app.js"
    ],
    "coverageThreshold": {
      "./src/utils/guardrails.js": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  },
  "keywords": [
    "election",
    "civic",
    "voting",
    "gemini",
    "accessibility",
    "education"
  ],
  "author": "CivicMind Contributors",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "axe-core": "^4.9.1",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jsdom": "^24.1.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
