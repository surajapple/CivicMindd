# ============================================================
#  CivicMind — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ─── SERVER ─────────────────────────────────────────────────
# Port the Express server listens on (Cloud Run sets this automatically)
PORT=8080

# ─── GOOGLE GEMINI API ───────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Gemini model to use (gemini-2.5-flash recommended for speed/cost balance)
GEMINI_MODEL=gemini-2.5-flash

# ─── GOOGLE CIVIC INFORMATION API ───────────────────────────
# Enable "Google Civic Information API" at: https://console.cloud.google.com
# Then create an API key restricted to this API only.
CIVIC_API_KEY=YOUR_CIVIC_API_KEY_HERE

# ─── GOOGLE CALENDAR API ─────────────────────────────────────
# Enable "Google Calendar API" at: https://console.cloud.google.com
# NOTE: CivicMind uses calendar deep-links (no OAuth needed for basic use).
# This key is used for any future server-side Calendar API calls.
CALENDAR_API_KEY=YOUR_CALENDAR_API_KEY_HERE

# ─── RATE LIMITING ───────────────────────────────────────────
# Global rate limit: max requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Strict rate limit for AI endpoint: max requests per window per IP
GEMINI_RATE_LIMIT_MAX=15

# ─── CACHING ─────────────────────────────────────────────────
# Time-to-live for Civic API responses (seconds). Default: 3600 (1 hour)
CIVIC_CACHE_TTL=3600

# Time-to-live for Gemini response cache (seconds). Default: 300 (5 min)
GEMINI_CACHE_TTL=300

# ─── CORS ────────────────────────────────────────────────────
# Allowed origin(s) for CORS. Use '*' for development, your domain for production.
# Example: https://civicmind.run.app
CORS_ORIGIN=*

# ─── LOGGING ─────────────────────────────────────────────────
# Morgan log format: 'combined' (prod) | 'dev' (local)
LOG_FORMAT=dev

# ─── NODE ENVIRONMENT ────────────────────────────────────────
NODE_ENV=development
